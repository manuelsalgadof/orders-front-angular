# Copia este archivo como .env en D:\Proyectos Personales\ y completa los valores reales
# NUNCA commitear .env — debe estar en .gitignore

# Base de datos
ConnectionStrings__DefaultConnection=Server=...;Database=OrdersDb;User Id=...;Password=...;Encrypt=True;

# JWT — mínimo 32 caracteres
Jwt__Key=CHANGE_ME_MIN_32_CHARS_SECRET_KEY_HERE
Jwt__Issuer=OrdersApi
Jwt__Audience=OrdersApiUsers

# Admin seed (solo se ejecuta si no existe ningún usuario)
ADMIN_SEED_NAME=Admin
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=CHANGE_ME_STRONG_PASSWORD
